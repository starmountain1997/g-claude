# ==============================================================================
# Hermes 性能分析平台 - 环境配置文件示例
# ==============================================================================
# 复制此文件为 .env 并填写实际配置

# ------------------------------
# 大模型配置
# ------------------------------
# 大模型 API Key（从模型服务提供商获取）
OPENAI_API_KEY=<your-api-key>

# 大模型 API 基础地址
OPENAI_API_BASE=<your-api-base-url>

# ------------------------------
# msagent 配置
# ------------------------------
# msagent web 服务地址
MSAGENT_API_URL=http://127.0.0.1:2025

# ------------------------------
# Flask 后端服务配置
# ------------------------------
# 服务端口
PORT=8082

# 文件上传目录
UPLOAD_FOLDER=uploads

# 会话超时时间（分钟）
SESSION_TIMEOUT=30

# ------------------------------
# 日志配置
# ------------------------------
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG
